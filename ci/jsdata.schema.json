{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InstaRishta Data",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "body", "gender", "date"],
    "properties": {
      "id": {
        "type": ["string", "number"]
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "body": {
        "type": "string",
        "minLength": 1
      },
      "gender": {
        "type": "string",
        "enum": ["male", "female", "unknown", "Male", "Female", "Unknown"]
      },
      "date": {
        "type": ["string", "number"]
      },
      "phone": {
        "type": ["string", "number", "null"]
      },
      "whatsapp": {
        "type": ["string", "number", "null"]
      },
      "age": {
        "type": ["string", "number", "null"]
      },
      "priority": {
        "type": ["string", "null"]
      },
      "education": {
        "type": ["string", "null"]
      },
      "values": {
        "type": ["string", "null"]
      },
      "verified": {
        "type": ["boolean", "string", "null"]
      },
      "familyApproval": {
        "type": ["boolean", "string", "null"]
      },
      "contactMode": {
        "type": ["string", "null"],
        "enum": ["direct", "family", "private", "Direct", "Family", "Private", null]
      },
      "guardianName": {
        "type": ["string", "null"]
      },
      "guardianPhone": {
        "type": ["string", "number", "null"]
      },
      "contactNotes": {
        "type": ["string", "null"]
      },
      "voiceId": {
        "type": ["string", "null"]
      },
      "voicePath": {
        "type": ["string", "null"]
      },
      "voiceLabel": {
        "type": ["string", "null"]
      },
      "voiceDurationSec": {
        "type": ["number", "string", "null"]
      },
      "voiceEnabled": {
        "type": ["boolean", "string", "null"]
      },
      "instagramPostId": {
        "type": ["string", "null"]
      },
      "biodataUrl": {
        "type": ["string", "null"]
      }
    },
    "additionalProperties": true
  }
}
