{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InstaRishta Data",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "body", "gender", "date"],
    "properties": {
      "id": {
        "type": ["string", "number"]
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "body": {
        "type": "string",
        "minLength": 1
      },
      "gender": {
        "type": "string",
        "enum": ["male", "female", "unknown", "Male", "Female", "Unknown"]
      },
      "date": {
        "type": ["string", "number"]
      },
      "phone": {
        "type": ["string", "number", "null"]
      },
      "whatsapp": {
        "type": ["string", "number", "null"]
      },
      "age": {
        "type": ["string", "number", "null"]
      },
      "priority": {
        "type": ["string", "null"]
      },
      "education": {
        "type": ["string", "null"]
      }
    },
    "additionalProperties": true
  }
}
